  "additionalProperties": false,
  "description": "Authoritative Payload v1.0 schema (ADR-0010).",
  "properties": {
    "payload_version": {
      "const": "1.0",
      "title": "Payload Version",
      "type": "string"
    },
    "idempotency_key": {
      "minLength": 8,
      "title": "Idempotency Key",
      "type": "string"
    },
    "site_id": {
      "format": "uuid4",
