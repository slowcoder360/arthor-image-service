# arthor-image-service environment configuration
# Copy to .env and fill in real values: cp .env.example .env
# All vars are read by app/config.py (Settings). Names are case-insensitive.

# --- Postgres (required for runs/payloads/assets persistence) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arthor_image

# --- HMAC ingress secret (required to call the signed POST endpoints) ---
# Shared with arthor-ai / arthor-agent. Used to verify X-Arthor-Signature.
FASTAPI_ARTHOR_SHARED_SECRET=dev-shared-secret-change-me

# --- Inspector UI auth (required to log into /inspector) ---
INSPECTOR_ADMIN_TOKEN=dev-inspector-token-change-me

# --- Cloudflare R2 storage (required to upload generated assets) ---
R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=arthor-media

# --- Image providers (set at least one for real generation) ---
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Tuning knobs (optional; defaults shown from app/config.py) ---
MAX_CONCURRENT_PACKS=4
PALETTE_DRIFT_THRESHOLD=25.0
COLD_STORAGE_INTERVAL_SECONDS=86400
LOG_LEVEL=INFO
